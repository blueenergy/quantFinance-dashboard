# ============================================
# quantFinance Dashboard 环境变量配置模板
# ============================================
# 复制此文件为 .env 并根据你的环境修改值

# ✅ 后端 API 基础 URL
# quantFinance FastAPI 后端运行在 3001 端口
VITE_API_BASE=http://localhost:3001/api

# ✅ Strategy Worker API 地址（已集成到 quantFinance FastAPI 后端）
# 无需单独的 Flask 服务器！直接使用 quantFinance 的 /api/strategy/workers 端点
VITE_WORKER_API=http://localhost:3001/api/strategy/workers

# ============================================
# 远程服务器部署时的配置示例
# ============================================

# 示例 1: 同网络（内网访问）
# VITE_API_BASE=http://192.168.1.100:3001/api
# VITE_WORKER_API=http://192.168.1.100:3001/api/strategy/workers

# 示例 2: SSH 隧道转发（本地开发连接远程）
# ssh -L 3001:localhost:3001 user@remote-server.com
# VITE_API_BASE=http://localhost:3001/api
# VITE_WORKER_API=http://localhost:3001/api/strategy/workers

# 示例 3: Nginx 反向代理（生产环境）
# VITE_API_BASE=https://strategy.example.com/api
# VITE_WORKER_API=https://strategy.example.com/api/strategy/workers

# ============================================
# 其他配置（可选）
# ============================================

# 日志级别
VITE_LOG_LEVEL=debug

# 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT=30000
